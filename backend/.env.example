# Penny Customer Care - Backend Environment Variables

APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=https://your-public-api-host.example.com
DEMO_LOGIN_ENABLED=true

GHOST_DATABASE_URL=postgresql://username:password@host:5432/database

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-spa-client-id
AUTH0_AUDIENCE=https://your-api-audience/
AUTH0_MANAGEMENT_API_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/
AUTH0_M2M_CLIENT_ID=your-auth0-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-auth0-m2m-client-secret

BLAND_API_KEY=your-bland-api-key
BLAND_SUPPORT_VOICE_ID=your-support-voice-id
BLAND_APPROVAL_VOICE_ID=your-approval-voice-id

NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=your-nvidia-nim-api-key
NIM_MODEL=qwen/qwen3-next-80b-a3b-instruct
